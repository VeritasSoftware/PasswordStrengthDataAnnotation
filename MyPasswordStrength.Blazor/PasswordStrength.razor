@using Microsoft.AspNetCore.Components.Forms;

@inherits InputBase<string>

<input
    placeholder="@Placeholder"
    @attributes="AdditionalAttributes"
    class="@CssClass"
    style="@Style"
    type="@(ShowPassword ? "text" : "password")"
    value="@CurrentValue"
    @oninput="HandleChange" />

@code {
    private ValidationMessageStore? _messageStore;
    private PasswordStrengthValidator _validator = new PasswordStrengthValidator();

    [Parameter]
    public string Placeholder { get; set; } = "Enter password";

    [Parameter] 
    public string Style { get; set; } = string.Empty;

    [Parameter]
    public MyPasswordStrengthOptions StrengthOptions { get; set; } = new MyPasswordStrengthOptions();

    [Parameter]
    public Action<string?, bool?>? OnValidation { get; set; }

    [Parameter]
    public bool ShowPassword { get; set; } = false;

    [Parameter]
    public string ErrorMessage { get; set; } = "Password does not meet the required strength criteria.";

    protected override void OnInitialized()
    {
        if (EditContext != null)
            _messageStore = new ValidationMessageStore(EditContext);

        _validator = new PasswordStrengthValidator
        {
            Language = StrengthOptions.Language,
            MinimumLength = StrengthOptions.MinimumLength,
            RequireUppercase = StrengthOptions.RequireUppercase,
            RequireLowercase = StrengthOptions.RequireLowercase,
            RequireDigit = StrengthOptions.RequireDigit,
            RequireSpecialCharacter = StrengthOptions.RequireSpecialCharacter,
            RequireMaxNoOfConsecutiveAscendingDigits = StrengthOptions.RequireMaximumNoOfConsecutiveAscendingDigits,
            RequireMaxNoOfConsecutiveDescendingDigits = StrengthOptions.RequireMaximumNoOfConsecutiveDescendingDigits,
            RequireMaxNoOfConsecutiveAscendingCharacters = StrengthOptions.RequireMaximumNoOfConsecutiveAscendingCharacters,
            RequireMaxNoOfConsecutiveDescendingCharacters = StrengthOptions.RequireMaximumNoOfConsecutiveDescendingCharacters,
            RequireMaxNoOfSameConsecutiveCharacters = StrengthOptions.RequireMaximumNoOfSameConsecutiveCharacters,
            RequireRepeatingSequenceCheck = StrengthOptions.RequireRepeatingSequenceCheck,
            MinUppercase = StrengthOptions.MinimumUppercase,
            MinLowercase = StrengthOptions.MinimumLowercase,
            MinDigit = StrengthOptions.MinimumDigit,
            MinSpecialCharacter = StrengthOptions.MinimumSpecialCharacter,
            MinLengthOfRepeatingSequence = StrengthOptions.MinimumLengthOfRepeatingSequence,
            MaxNoOfConsecutiveAscendingDigits = StrengthOptions.MaximumNoOfConsecutiveAscendingDigits,
            MaxNoOfConsecutiveDescendingDigits = StrengthOptions.MaximumNoOfConsecutiveDescendingDigits,
            MaxNoOfConsecutiveAscendingCharacters = StrengthOptions.MaximumNoOfConsecutiveAscendingCharacters,
            MaxNoOfConsecutiveDescendingCharacters = StrengthOptions.MaximumNoOfConsecutiveDescendingCharacters,
            MaxNoOfSameConsecutiveCharacters = StrengthOptions.MaximumNoOfSameConsecutiveCharacters
        };

        base.OnInitialized();
    }

    private void HandleChange(ChangeEventArgs e)
    {
        var newPwd = e.Value?.ToString() ?? string.Empty;

        CurrentValueAsString = newPwd;                

        OnPasswordChanged(CurrentValueAsString);

        // Notify EditContext so ValidationSummary updates
        if (EditContext != null)
        {
            EditContext.NotifyFieldChanged(FieldIdentifier);
        }

        StateHasChanged();
    }

    private void OnPasswordChanged(string password)
    {
        if (_messageStore != null)
        {
            _messageStore.Clear(FieldIdentifier);
        }

        if (string.IsNullOrEmpty(password))
        {
            OnValidation?.Invoke(password, null);
            return;
        }                

        var isValid = _validator.PasswordStrength(password);

        if (_messageStore != null && !isValid)
        {
            _messageStore.Add(FieldIdentifier, ErrorMessage);
        }

        OnValidation?.Invoke(password, isValid);
    }

    protected override bool TryParseValueFromString(string? value, out string result, out string validationErrorMessage)
    {
        result = value ?? string.Empty;
        validationErrorMessage = null!;
        return true;        
    }
}